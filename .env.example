NODE_ENV=production
#
## DEBUG patterns ##
# Comma-separated list of full category names. An entry must match the full name:
# DEBUG=llm:summarizer does NOT enable 'llm' or 'summarizer'. 'llm:*' enables the whole llm:... family,
# '*' enables everything. Example: DEBUG=llm,img-gen
#
# llm            - LLM calls: requests (model, message/tool counts) and responses (first 400 chars, chunk stats)
# llm:summarizer - history compression (summarizer): cold-zone size, summarizer errors, compression stats
# llm:*          - whole llm:... family (llm + llm:summarizer)
# mcp:tool       - MCP tool calls: request arguments and response payloads, reconnects on dropped connections
# img-gen        - image generation: all stages from tool call to Telegram delivery — API request/response,
#                  sending photo by URL and multipart-upload fallback
#
# DEBUG=llm:*,mcp:*,img-gen
