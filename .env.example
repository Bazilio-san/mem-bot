DATABASE_URL=postgresql://<user>:<passw>@localhost:5432/<db_name>

# ===== Аутентификация =====
# Сгенерируй длинную случайную строку:
#   bun -e "console.log(crypto.randomBytes(48).toString('base64'))"
# или (если есть openssl):
#   openssl rand -base64 48
AUTH_SECRET=***

# ===== LLM-провайдер =====
# Запросы идут через корпоративный LiteLLM-прокси (OpenAI-совместимый API),
# а не на api.openai.com. На этапе 16 в src/server/llm/provider.ts фабрика
# провайдера читает OPENAI_BASE_URL и создаёт OpenAI-клиент через
# createOpenAI({ apiKey, baseURL }).
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
# aite-vvmakarov
OPENAI_API_KEY=***
OPENAI_BASE_URL=https://litellm.finam.ru/v1
# Опционально, если будешь переключаться на Anthropic через LLM_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://litellm.finam.ru/v1   # тот же прокси, если поддерживается

# ===== Web search (этап 18) =====
# Регистрация: https://tavily.com — бесплатный тариф 1000 запросов/мес.
TAVILY_API_KEY=***
ASSEMBLYAI_API_KEY=***
GROQ_API_KEY=***

TELEGRAM_BOT_URL=
TELEGRAM_BOT_ID=
TELEGRAM_BOT_NAME=
TELEGRAM_BOT_USERNAME=
TELEGRAM_API_KEY=

DEBUG=llm,llm:web-extract:dump
# ===== Отладочные логи (DEBUG) =====
# Включают трассировку в консоли сервера по именам категорий (через запятую).
# Категория `llm` печатает запрос к модели, её ответ и вызовы инструментов.
# Категория `llm:summarizer` печатает вызовы суммаризатора (сжатие истории).
#   DEBUG=llm             — только основной агент
#   DEBUG=llm:summarizer  — только суммаризатор
#   DEBUG=llm:*           — и агент, и суммаризатор
#   DEBUG=*               — все категории
# Раскомментируй нужную строку:
# DEBUG=llm

# ===== Прочее =====
PUBLIC_URL=http://localhost:3002
PORT=3002
LOG_LEVEL=debug
NODE_ENV=production

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tg_fli
DB_USERNAME=***
DB_PASSWORD=***

# ===== Режим собеседника и проактивность (по умолчанию всё выключено) =====
# Темпоральный и тематический контекст в ответах + извлечение тем после ответа:
COMPANION_MODE=off
# Проактивный контур: бот пишет первым по триггерам с анти-спамом:
PROACTIVE_ENABLED=off
# Внешние события (новости) как поводы написать (требует PROACTIVE_ENABLED=on):
PROACTIVE_EVENTS_ENABLED=off
# Тонкая настройка (можно не задавать — есть значения по умолчанию):
PROACTIVE_INTERVAL_MS=300000
PROACTIVE_INACTIVITY_MIN=1440
PROACTIVE_CHECKIN_HOUR=10
PROACTIVE_GOAL_INTERVAL_MIN=2880
PROACTIVE_WELCOME_GAP_MIN=60
NEWS_RELEVANCE_THRESHOLD=0.6