# Базовая строка подключения к Postgres; из неё создаётся/выбирается БД памяти.
DATABASE_URL=postgresql://<user>:<passw>@localhost:5432/<db_name>
# Имя отдельной БД памяти агента, если MEM_DATABASE_URL не задан.
MEM_DB_NAME=agent_mem
# Полная строка подключения к рабочей БД памяти; переопределяет DATABASE_URL + MEM_DB_NAME.
MEM_DATABASE_URL=postgresql://<user>:<passw>@localhost:5432/agent_mem

# ===== Аутентификация =====
# Сгенерируй длинную случайную строку:
#   bun -e "console.log(crypto.randomBytes(48).toString('base64'))"
# или (если есть openssl):
#   openssl rand -base64 48
AUTH_SECRET=***

# ===== LLM-провайдер =====
# Запросы идут через LiteLLM-прокси (OpenAI-совместимый API),
# а не на api.openai.com. На этапе 16 в src/server/llm/provider.ts фабрика
# провайдера читает OPENAI_BASE_URL и создаёт OpenAI-клиент через
# createOpenAI({ apiKey, baseURL }).
LLM_PROVIDER=openai
# aite-vvmakarov
OPENAI_API_KEY=***
OPENAI_BASE_URL=https://litellm.my-proxy.com/v1
# Основная модель агента для ответов пользователю и вызова инструментов.
MAIN_MODEL=gpt-5.4-mini
# Быстрая вспомогательная модель для классификации запросов и коротких служебных задач.
AUX_MODEL=gpt-5.4-nano
# Модель извлечения фактов в память.
EXTRACT_MODEL=gpt-5.4-mini
# Модель эмбеддингов для смыслового поиска по памяти.
EMBED_MODEL=text-embedding-3-small

CEREBRAS_API_KEY=***
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Опционально, если будешь переключаться на Anthropic через LLM_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://litellm.my-proxy.com/v1   # тот же прокси, если поддерживается

# ===== Web search (этап 18) =====
# Регистрация: https://tavily.com — бесплатный тариф 1000 запросов/мес.
TAVILY_API_KEY=***
ASSEMBLYAI_API_KEY=***
GROQ_API_KEY=***

TELEGRAM_BOT_URL=
TELEGRAM_BOT_ID=
TELEGRAM_BOT_NAME=
TELEGRAM_BOT_USERNAME=
TELEGRAM_API_KEY=
# Предел одновременных тяжёлых обработок входящих сообщений (одновременных вызовов LLM), общий по всем чатам.
# Разные чаты обрабатываются параллельно, внутри одного чата — строго по порядку. По умолчанию 5:
TELEGRAM_MAX_CONCURRENCY=5
# Как часто (в миллисекундах) страховочный таймер опустошает очередь доставки. Основной путь событийный
# (LISTEN/NOTIFY), этот проход подстраховывает на случай пропущенного уведомления. По умолчанию 30000:
OUTBOX_SAFETY_INTERVAL_MS=30000
# Границы адаптивного сна воркера планировщика (в миллисекундах). Воркер спит до момента ближайшей задачи и
# просыпается мгновенно по уведомлению о новой задаче (канал scheduler_wake). Нижняя граница не даёт частить,
# когда задачи идут вплотную; верхняя задаёт максимальную паузу между перепроверками базы. По умолчанию 250 и 30000:
SCHEDULER_MIN_SLEEP_MS=250
SCHEDULER_MAX_SLEEP_MS=30000

# ===== Отладочные логи (DEBUG) =====
# Включают трассировку в консоли сервера по именам категорий (через запятую).
# Категория `llm` печатает запрос к модели, её ответ и вызовы инструментов.
# Категория `llm:summarizer` печатает вызовы суммаризатора (сжатие истории).
#   DEBUG=llm             — только основной агент
#   DEBUG=llm:summarizer  — только суммаризатор
#   DEBUG=llm:*           — и агент, и суммаризатор
#   DEBUG=mcp:tool        — инструменты
#   DEBUG=*               — все категории
DEBUG=llm,llm:web-extract:dump

# ===== Прочее =====
PUBLIC_URL=http://localhost:3002
PORT=3002
LOG_LEVEL=debug
NODE_ENV=production
# Часовой пояс по умолчанию для логики дат и времени.
TZ_DEFAULT=Europe/Moscow

DB_HOST=localhost
DB_PORT=5432
DB_NAME=tg_fli
DB_USERNAME=***
DB_PASSWORD=***

# ===== Распознавание входящего аудио (речь в текст, STT; по умолчанию выключено) =====
# Общий выключатель. При off голосовые сообщения, кружки и присланные аудио/видео игнорируются, как и раньше:
VOICE_INPUT_ENABLED=off
# Выбор распознавателя. Поддерживаются: groq-whisper-large-v3-turbo (по умолчанию, нужен GROQ_API_KEY),
# groq-whisper-large-v3 (GROQ_API_KEY), assemblyai-universal-2 (ASSEMBLYAI_API_KEY),
# openai-gpt-4o-transcribe и openai-gpt-4o-mini-transcribe (через прокси, нужен OPENAI_API_KEY):
VOICE_INPUT_PROVIDER=groq-whisper-large-v3-turbo
# Предел длительности входящего аудио или видео в секундах (по умолчанию 300 — пять минут):
VOICE_INPUT_MAX_SECONDS=300
# Предел размера вложения в байтах, когда длительность неизвестна или файл прислан документом (по умолчанию 25 МБ):
VOICE_INPUT_MAX_BYTES=25000000
# Код языка-подсказки для распознавателя (по умолчанию ru) — улучшает точность и скорость:
VOICE_INPUT_LANG=ru

# ===== Голосовой ответ бота (текст в речь, TTS; по умолчанию выключено) =====
# Общий выключатель синтеза голосовых ответов. При off бот всегда отвечает текстом, а инструмент set_reply_mode
# (переключение «отвечай голосом / текстом») не подключается. Синтез идёт через тот же прокси (audio/speech):
VOICE_OUTPUT_ENABLED=off
# Модель синтеза речи на прокси (подтверждена практической проверкой, отдаёт русский и формат OGG/OPUS):
VOICE_OUTPUT_MODEL=openai/gpt-4o-mini-tts
# Идентификатор голоса (тембр). Язык речи задавать не нужно — он подстраивается под язык текста ответа:
VOICE_OUTPUT_VOICE=alloy
# Формат вывода. opus даёт OGG/OPUS для прямой отправки в Telegram через sendVoice без перекодировки:
VOICE_OUTPUT_FORMAT=opus
# Жёсткий предел длины текста для синтеза в символах (значение по умолчанию и максимум — 500). Более длинный
# ответ не озвучивается целиком: вместо него синтезируется резюме, а полный ответ отправляется текстом:
VOICE_OUTPUT_MAX_CHARS=500
# Порог длины самого резюме в символах (не больше общего предела), чтобы голосовое сообщение было коротким:
VOICE_OUTPUT_SUMMARY_MAX_CHARS=500
# Модель построения резюме для длинных ответов и ответов с кодом или списками (по умолчанию AUX_MODEL):
VOICE_OUTPUT_SUMMARY_MODEL=gpt-5.4-nano

# ===== Режим собеседника и проактивность (по умолчанию всё выключено) =====
# Темпоральный и тематический контекст в ответах + извлечение тем после ответа:
COMPANION_MODE=off
# Проактивный контур: бот пишет первым по триггерам с анти-спамом:
PROACTIVE_ENABLED=off
# Внешние события (новости) как поводы написать (требует PROACTIVE_ENABLED=on):
PROACTIVE_EVENTS_ENABLED=off
# Тонкая настройка (можно не задавать — есть значения по умолчанию):
# Как часто воркер проверяет проактивные триггеры, мс.
PROACTIVE_INTERVAL_MS=300000
# Через сколько минут неактивности можно отправить мягкий check-in.
PROACTIVE_INACTIVITY_MIN=1440
# Час дня для планового check-in по локальному часовому поясу.
PROACTIVE_CHECKIN_HOUR=10
# Минимальный интервал в минутах между проактивными сообщениями по целям.
PROACTIVE_GOAL_INTERVAL_MIN=2880
# Минимальный разрыв в минутах для приветствия после возвращения пользователя.
PROACTIVE_WELCOME_GAP_MIN=60
# Мягкий дневной лимит проактивных сообщений без явной просьбы пользователя.
PROACTIVE_SOFT_DAILY_LIMIT=1
# Мягкий недельный лимит проактивных сообщений без явной просьбы пользователя.
PROACTIVE_SOFT_WEEKLY_LIMIT=3
# Дневной лимит проактивных напоминаний, которые пользователь явно запросил.
PROACTIVE_REQUESTED_REMINDER_DAILY_LIMIT=2
# Минимальная пауза в минутах между мягкими проактивными контактами.
PROACTIVE_MIN_SOFT_PAUSE_MIN=360
# Число оставленных без ответа проактивных сообщений, после которого включается тишина.
PROACTIVE_QUIET_AFTER_UNANSWERED=2
# Длительность тишины в часах после серии проигнорированных проактивных сообщений.
PROACTIVE_QUIET_HOURS_AFTER_IGNORES=24
# Порог релевантности внешнего события или новости для проактивного повода написать.
NEWS_RELEVANCE_THRESHOLD=0.6

# ===== Потоковая обратная связь =====
# Включает потоковый вызов модели в ядре агента.
LLM_STREAMING_ENABLED=true
# Включает редактируемый черновик потокового ответа в Telegram.
TELEGRAM_STREAMING_ENABLED=true
# Минимальный интервал между редактированиями потокового ответа в Telegram, мс.
TELEGRAM_STREAM_EDIT_INTERVAL_MS=900
# Минимальный объём новых символов перед очередным редактированием потокового ответа.
TELEGRAM_STREAM_MIN_EDIT_CHARS=20
# Показывать ли статусы вызовов инструментов в Telegram во время ответа.
TELEGRAM_TOOL_STATUS_ENABLED=true

# ===== Поджатие истории диалога (опционально) =====
# Сжимает старую часть истории в компактный дайджест; последние HISTORY_HOT_WINDOW сообщений
# всегда передаются дословно. По умолчанию выключено, поведение бота не меняется.
# слой сжатой истории диалога (`HISTORY_CONTEXT` поверх горячего окна
HISTORY_COMPRESSION_ENABLED=true
# сколько последних сообщений уходит в запрос дословно
HISTORY_HOT_WINDOW=8
# порог размера холодной зоны, при превышении запускается сжатие
HISTORY_MAX_TOKENS=2000
# целевой размер дайджеста после сжатия (должен быть меньше `HISTORY_MAX_TOKENS`)
HISTORY_SHRINK_TOKENS=800
# доли бюджета дайджеста на ближнюю, среднюю и дальнюю зоны
HISTORY_ZONE_WEIGHTS=0.55,0.30,0.15
# модель суммаризатора истории (по умолчанию `AUX_MODEL`)
HISTORY_SUMMARY_MODEL=gpt-5.4-nano
#  минимальный выигрыш сжатия, ниже которого пересжатие не выполняется
HISTORY_MIN_COMPRESS_GAIN=0.35

# ===== Лимиты минимизации памяти (сколько фактов каждой области попадает в промпт) =====
# Релевантные факты ранжируются и обрезаются до этих значений. По умолчанию — прежние константы.
# устойчивые факты о пользователе и стиле общения (профильная память)
MEMORY_LIMIT_PROFILE=7
# факты текущего диалога
MEMORY_LIMIT_DIALOG=5
# факты предметной области (домена)
MEMORY_LIMIT_DOMAIN=12
# активные напоминания
MEMORY_LIMIT_REMINDER=3
# безопасные резюме защищённых данных
MEMORY_LIMIT_SECURE=3
# общий потолок числа фактов в промпте
MEMORY_LIMIT_TOTAL=30

# ===== Глобальная память и база знаний =====
# Включает общий слой глобальных фактов, подмешиваемых в каждый запрос.
GLOBAL_MEMORY_ENABLED=off
# Сколько глобальных фактов подмешивать в каждый запрос.
GLOBAL_FACTS_LIMIT=5
# Включает общую RAG-базу знаний и инструменты работы с ней.
GLOBAL_RAG_ENABLED=off
# Сколько фрагментов общей базы знаний подмешивать по релевантности.
GLOBAL_RAG_LIMIT=5
# Минимальная релевантность фрагмента общей базы знаний для попадания в контекст.
GLOBAL_RAG_MIN_RELEVANCE=0.3

# ===== Схемы доменных фактов =====
# Порог косинусной близости при канонизации fixed_vocab ключей по эмбеддингу.
SCHEMA_KEY_EMBED_THRESHOLD=0.82

# ===== Инструментарий создания и редактирования навыков (только для администратора) =====
# Включает инструменты skill_author_* у администратора. Без этого флага они не подключаются даже админу.
SKILL_AUTHORING_ENABLED=off
