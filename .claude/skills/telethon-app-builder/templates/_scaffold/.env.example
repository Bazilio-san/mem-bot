# Copy to .env and fill in. NEVER commit the real .env. (.env and sessions/ belong in .gitignore.)

# From https://my.telegram.org/apps  (identifies your application, not the account)
API_ID=
API_HASH=

# On-disk SQLite session path (a credential — keep it out of git).
SESSION_NAME=sessions/account

# Only for a BOT login (from @BotFather). Leave empty for a user-account app.
BOT_TOKEN=

# Optional: portable StringSession value (use instead of a session file in containers/CI).
SESSION_STRING=
