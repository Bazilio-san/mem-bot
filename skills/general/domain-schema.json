{
  "domain_key": "general",
  "title": "General assistant",
  "description": "Base domain without a narrow specialization. General-purpose domain entities.",
  "allowed_memory_kinds": ["fact", "preference", "constraint", "goal", "relationship", "state", "history", "instruction", "communication_style", "reminder"],
  "entities": [
    {
      "entity_type": "person",
      "description": "A person the user told about (relative, colleague, acquaintance).",
      "entity_key": { "mode": "slug" },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "relation", "notes"],
        "properties": {
          "name": { "type": ["string", "null"] },
          "relation": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    {
      "entity_type": "note",
      "description": "An arbitrary domain note about something worth remembering.",
      "entity_key": { "mode": "slug" },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "content"],
        "properties": {
          "topic": { "type": ["string", "null"] },
          "content": { "type": ["string", "null"] }
        }
      }
    },
    {
      "entity_type": "communication_style",
      "description": "The user's stable communication style and preferences about the form of the answer.",
      "entity_key": {
        "mode": "fixed_vocab",
        "vocabulary": [
          "short_direct",
          "streamed_answers",
          "text_not_voice",
          "notification_first_person",
          "emoji_chat_names",
          "informal_tone"
        ],
        "synonyms": {
          "short_direct": ["коротко", "кратко", "прямо", "без лишнего"],
          "streamed_answers": ["стриминг", "ответы частями", "по мере генерации"],
          "text_not_voice": ["текстом", "не голосом", "не устно"],
          "notification_first_person": ["от первого лица", "напоминаю"],
          "emoji_chat_names": ["like", "okay", "heart"],
          "informal_tone": ["неформально", "живой стиль", "без формальностей"]
        }
      },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["preference", "notes"],
        "properties": {
          "preference": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    {
      "entity_type": "feature_request",
      "description": "A long-term wish of the user regarding the assistant's capabilities.",
      "entity_key": {
        "mode": "fixed_vocab",
        "vocabulary": [
          "streaming_responses",
          "global_memory",
          "reminder_view",
          "bot_menu",
          "status_command",
          "audio_recognition",
          "emoji_reactions",
          "log_analysis",
          "self_development"
        ],
        "synonyms": {
          "streaming_responses": ["стриминг", "ответы частями"],
          "global_memory": ["глобальная память"],
          "reminder_view": ["просмотр напоминаний", "активные напоминания"],
          "bot_menu": ["бот-меню", "меню бота"],
          "status_command": ["команда status", "status"],
          "audio_recognition": ["распознавание звука", "распознавание аудио"],
          "emoji_reactions": ["emoji", "эмодзи", "реакции"],
          "log_analysis": ["анализ логов"],
          "self_development": ["саморазвитие"]
        }
      },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request", "status"],
        "properties": {
          "request": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] }
        }
      }
    }
  ]
}
