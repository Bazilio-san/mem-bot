{
  "domain_key": "math_tutor",
  "title": "Math tutor",
  "description": "The student's topics, mistakes and progress in mathematics.",
  "allowed_memory_kinds": ["preference", "goal", "progress", "state", "history"],
  "entities": [
    {
      "entity_type": "topic",
      "description": "A topic the student is working on, and their level of understanding.",
      "entity_key": { "mode": "slug" },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["understanding", "notes"],
        "properties": {
          "understanding": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    {
      "entity_type": "mistake",
      "description": "A typical mistake of the student that is worth practicing.",
      "entity_key": { "mode": "slug" },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "topic"],
        "properties": {
          "description": { "type": ["string", "null"] },
          "topic": { "type": ["string", "null"] }
        }
      }
    },
    {
      "entity_type": "goal",
      "description": "The student's learning goal.",
      "entity_key": { "mode": "slug" },
      "data_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "deadline"],
        "properties": {
          "description": { "type": ["string", "null"] },
          "deadline": { "type": ["string", "null"] }
        }
      }
    }
  ]
}
